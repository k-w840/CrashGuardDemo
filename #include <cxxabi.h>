 #include <jni.h>
#include <unordered_map>

// 存储【原始 C++ 函数指针】的全局路由表
std::unordered_map<void*, void*> g_orig_jni_methods;

// 防火墙动态跳板（Proxy）
jboolean jni_firewall_proxy_jboolean(JNIEnv *env, jobject thiz, ...) {
    // 1. 通过调用栈或寄存器，动态识别当前被调用的原始函数指针
    void* orig_func = lookup_current_orig_func(); 
    
    // 2. 核心防火墙 try-catch
    try {
        // 动态调用原函数
        typedef jboolean (*orig_type)(JNIEnv*, jobject, ...);
        return ((orig_type)orig_func)(env, thiz);
    } catch (const std::exception& e) {
        // 3. 拦截 C++ 异常，安全转换为 Java 异常
        jclass exClass = env->FindClass("com/example/dwgviewer/DWGParseException");
        env->ThrowNew(exClass, e.what());
        return JNI_FALSE;
    }
}

// Hook 系统的 RegisterNatives 后，我们的代理注册函数
jint my_RegisterNatives(JNIEnv* env, jclass clazz, const JNINativeMethod* methods, jint nMethods) {
    JNINativeMethod* review_methods = new JNINativeMethod[nMethods];
    
    for (int i = 0; i < nMethods; ++i) {
        review_methods[i].name = methods[i].name;
        review_methods[i].signature = methods[i].signature;
        
        // 核心亮点：把原本的 C++ 函数指针（methods[i].fnPtr）存起来
        g_orig_jni_methods[methods[i].fnPtr] = methods[i].fnPtr;
        
        // 动态替换成我们的防火墙跳板函数指针
        review_methods[i].fnPtr = (void*)jni_firewall_proxy_jboolean;
    }
    
    // 调用系统原生的 RegisterNatives 完成真正注册
    return orig_RegisterNatives(env, clazz, review_methods, nMethods);
}


