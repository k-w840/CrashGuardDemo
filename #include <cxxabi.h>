#include <cxxabi.h>
#include <dlfcn.h>

namespace {
    using CxaThrowType = void (*)(void *, std::type_info *, void (*)(void *));
    CxaThrowType g_originalCxaThrow = nullptr;
}

extern "C" __attribute__((visibility("default")))
void __cxa_throw(void *thrownException,
                 std::type_info *tinfo,
                 void (*dest)(void *)) {
    // ★ throw 时刻：栈还没展开，这里抓到的就是真实 throw 现场
    LogCurrentUnwindStack("__cxa_throw captured at throw site");

    if (g_originalCxaThrow == nullptr) {
        g_originalCxaThrow = (CxaThrowType)dlsym(RTLD_NEXT, "__cxa_throw");
    }
    g_originalCxaThrow(thrownException, tinfo, dest);
    __builtin_unreachable();   // __cxa_throw 是 noreturn
}

这是利用 C++ 标准库行为进行的“大招级”验证。C++ 规定：如果在析构函数执行期间再次抛出异常，程序会不经过任何解栈，直接、强行调用 std::terminate()。

补充一个细节：throw;（重抛）走的是 __cxa_rethrow 而不是 __cxa_throw（你这张图 #3 就是证据）。所以如果你想连重抛点也抓全，hook 时两个都要 hook：__cxa_throw（首次抛）+ __cxa_rethrow（重抛）。对你课题主目标"定位最初 throw 现场"来说，hook __cxa_throw 就够了；hook __cxa_rethrow 是锦上添花，能还原完整的"抛→接→再抛"链路。

